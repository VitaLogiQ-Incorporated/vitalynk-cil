# CIL configuration via environment (prefix: CIL_). Copy to .env for local overrides.
# Anything here overrides config/default.yaml; real env vars override .env.

CIL_ENV=local
CIL_LOG_LEVEL=INFO
CIL_HOST=0.0.0.0
CIL_PORT=8000

# Path to the YAML config file (file-based config; env still wins over it).
CIL_CONFIG_FILE=config/default.yaml
